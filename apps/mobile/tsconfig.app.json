{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path mappings for monorepo packages (enables Ctrl+Click / Go to Definition) */
    "baseUrl": ".",
    "paths": {
      "@repo/ui": ["../../packages/ui/src"],
      "@repo/ui/*": ["../../packages/ui/src/*"],
      "@repo/api": ["../../packages/api/src"],
      "@repo/api/*": ["../../packages/api/src/*"],
      "@repo/hooks": ["../../packages/hooks/src"],
      "@repo/hooks/*": ["../../packages/hooks/src/*"],
      "@repo/config": ["../../packages/config"],
      "@repo/config/*": ["../../packages/config/*"],
      "@repo/types": ["../../packages/types/src"],
      "@repo/types/*": ["../../packages/types/src/*"],
      "@repo/util": ["../../packages/util/src"],
      "@repo/util/*": ["../../packages/util/src/*"],
      "@repo/i18n": ["../../packages/i18n/src"],
      "@repo/i18n/*": ["../../packages/i18n/src/*"],
      "@repo/antd-config": ["../../packages/antd-config/src"],
      "@repo/antd-config/*": ["../../packages/antd-config/src/*"],
      "@repo/tenant-config": ["../../packages/tenant-config/src"],
      "@repo/tenant-config/*": ["../../packages/tenant-config/src/*"],
      "@repo/theme-provider": ["../../packages/theme-provider/src"],
      "@repo/theme-provider/*": ["../../packages/theme-provider/src/*"],
      "@repo/tailwind-config": ["../../packages/tailwind-config/src"],
      "@repo/tailwind-config/*": ["../../packages/tailwind-config/src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src",
    "../../packages/*/src"
  ]
}

